{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lenroe.com/assets/content.schema.json",
  "title": "Homepage Content",
  "type": "object",
  "required": ["site", "about", "research", "contact", "footer"],
  "additionalProperties": false,
  "properties": {
    "site": {
      "type": "object",
      "required": ["name", "title", "tagline"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "tagline": { "type": "string", "minLength": 1 }
      }
    },
    "about": {
      "type": "object",
      "required": ["name", "image", "bio", "links"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "image": {
          "type": "object",
          "required": ["src", "alt", "width", "height"],
          "additionalProperties": false,
          "properties": {
            "src": { "type": "string", "minLength": 1 },
            "alt": { "type": "string", "minLength": 1 },
            "width": { "type": "integer", "minimum": 1 },
            "height": { "type": "integer", "minimum": 1 }
          }
        },
        "bio": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "links": {
          "type": "array",
          "items": { "$ref": "#/$defs/labeledLink" }
        }
      }
    },
    "research": {
      "type": "object",
      "required": ["title", "items"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/researchItem" }
        }
      }
    },
    "contact": {
      "type": "object",
      "required": ["title", "subtitle", "email"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "subtitle": { "type": "string", "minLength": 1 },
        "email": { "type": "string", "format": "email" }
      }
    },
    "footer": {
      "type": "object",
      "required": ["copyright", "signature"],
      "additionalProperties": false,
      "properties": {
        "copyright": { "type": "string", "minLength": 1 },
        "signature": { "type": "string", "minLength": 1 }
      }
    }
  },
  "$defs": {
    "labeledLink": {
      "type": "object",
      "required": ["label", "url"],
      "additionalProperties": false,
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" }
      }
    },
    "mediaImage": {
      "type": "object",
      "required": ["type", "src", "alt"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "image" },
        "src": { "type": "string", "minLength": 1 },
        "alt": { "type": "string", "minLength": 1 },
        "href": { "type": "string", "format": "uri" }
      }
    },
    "mediaVideo": {
      "type": "object",
      "required": ["type", "poster", "src"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "video" },
        "poster": { "type": "string", "minLength": 1 },
        "src": { "type": "string", "minLength": 1 }
      }
    },
    "researchItem": {
      "type": "object",
      "required": ["title", "authors", "summary", "media", "links"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "paperUrl": { "type": "string", "format": "uri" },
        "authors": { "type": "string", "minLength": 1 },
        "venue": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "media": {
          "oneOf": [
            { "$ref": "#/$defs/mediaImage" },
            { "$ref": "#/$defs/mediaVideo" }
          ]
        },
        "links": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/labeledLink" }
        }
      }
    }
  }
}
